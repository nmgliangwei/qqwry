#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/liangwei/mycode/qqwry/node_modules/.pnpm/lib-qqwry@1.3.4/node_modules/lib-qqwry/node_modules:/Users/liangwei/mycode/qqwry/node_modules/.pnpm/lib-qqwry@1.3.4/node_modules:/Users/liangwei/mycode/qqwry/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/liangwei/mycode/qqwry/node_modules/.pnpm/lib-qqwry@1.3.4/node_modules/lib-qqwry/node_modules:/Users/liangwei/mycode/qqwry/node_modules/.pnpm/lib-qqwry@1.3.4/node_modules:/Users/liangwei/mycode/qqwry/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../lib-qqwry/bin/qqwry" "$@"
else
  exec node  "$basedir/../lib-qqwry/bin/qqwry" "$@"
fi
