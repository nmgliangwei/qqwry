{
  "name": "opencc-js",
  "version": "1.3.1",
  "description": "The JavaScript version of Open Chinese Convert (OpenCC)",
  "main": "./dist/umd/full.js",
  "types": "./types/full.d.ts",
  "type": "module",
  "files": [
    "dist",
    "types",
    "README.md",
    "README-zh-CN.md",
    "README-zh-TW.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types/full.d.ts",
      "import": "./dist/esm/full.js",
      "require": "./dist/umd/full.js"
    },
    "./cn2t": {
      "types": "./types/full.d.ts",
      "import": "./dist/esm/cn2t.js",
      "require": "./dist/umd/cn2t.js"
    },
    "./t2cn": {
      "types": "./types/full.d.ts",
      "import": "./dist/esm/t2cn.js",
      "require": "./dist/umd/t2cn.js"
    },
    "./core": {
      "types": "./types/core.d.ts",
      "default": "./dist/esm-lib/core.js"
    },
    "./preset": {
      "types": "./types/preset.d.ts",
      "default": "./dist/esm-lib/preset/full.js"
    },
    "./preset/cn2t": {
      "types": "./types/preset.d.ts",
      "default": "./dist/esm-lib/preset/cn2t.js"
    },
    "./preset/t2cn": {
      "types": "./types/preset.d.ts",
      "default": "./dist/esm-lib/preset/t2cn.js"
    },
    "./*": "./dist/esm-lib/*.js"
  },
  "scripts": {
    "build": "node build.js && rollup -c",
    "benchmark": "npm run build && node benchmark/performance.mjs",
    "test": "npm run build && node test/node/basic.mjs && node test/node/basic.cjs && npm run test:opencc",
    "test:opencc": "node test/node/opencc-testcases.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nk2028/opencc-js.git"
  },
  "author": "The nk2028 Project",
  "keywords": [
    "opencc",
    "Chinese",
    "unicode",
    "Chinese Language",
    "Simplified Chinese",
    "Traditional Chinese",
    "chinese-language",
    "chinese-characters",
    "traditional-chinese",
    "simplified-chinese"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nk2028/opencc-js/issues"
  },
  "homepage": "https://github.com/nk2028/opencc-js#readme",
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "chai": "~4.3.4",
    "opencc-data": "1.3.1",
    "rollup-plugin-generate-package-json": "^3.2.0"
  }
}
